{
  "name": "glyphrow",
  "version": "3.0.5",
  "description": "Accessible, dependency-free type tester for the web — a vanilla JS core with an optional React wrapper. Composable OpenType features, variable-font axes, and auto-fit sizing.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./react": {
      "import": {
        "types": "./dist/react.d.ts",
        "default": "./dist/react.js"
      },
      "require": {
        "types": "./dist/react.d.cts",
        "default": "./dist/react.cjs"
      }
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.cjs",
    "dist/**/*.d.ts",
    "dist/**/*.d.cts",
    "dist/**/*.map",
    "dist/styles.css"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "capture": "node scripts/capture.mjs",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "typography",
    "web-typography",
    "type-tester",
    "font-tester",
    "type-specimen",
    "type-proofing",
    "font",
    "fonts",
    "opentype",
    "font-feature-settings",
    "variable-fonts",
    "font-variation-settings",
    "auto-fit",
    "glyphrow",
    "google-fonts",
    "react",
    "vanilla-js",
    "framework-agnostic",
    "accessibility",
    "zero-dependencies",
    "typescript",
    "css"
  ],
  "author": "Quinn Keaveney <quinn@liiift.studio>",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/quitequinn/glyphrow.git"
  },
  "homepage": "https://glyphrow.com",
  "bugs": {
    "url": "https://github.com/quitequinn/glyphrow/issues"
  },
  "peerDependencies": {
    "react": ">=17",
    "react-dom": ">=17"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "jsdom": "^25.0.0",
    "playwright": "^1.61.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.9"
  }
}
